@model GestionResiduos.Models.Residuo

@{
    <form asp-action="Edit">
        <input type="hidden" asp-for="IdResiduo" />
        <div class="mb-3">
            <label asp-for="NameResiduo" class="form-label"></label>
            <input asp-for="NameResiduo" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="TipoResiduo" class="form-label"></label>
            <select asp-for="TipoResiduo" class="form-control">
                <option value="Plástico">Plástico</option>
                <option value="Orgánico">Orgánico</option>
                <option value="Papel/Carton">Papel/Carton</option>
                <option value="Vidrio">Vidrio</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="PesoResiduo" class="form-label"></label>
            <input asp-for="PesoResiduo" type="number" step="0.01" class="form-control" />
        </div>
        <div class="form-grorp mb-3">
            <label asp-for="FechaRecoleccionResiduo" class="form-label"></label>
            <input asp-for="FechaRecoleccionResiduo" type="date" class="form-control" />
        </div>
        <div class="modal-footer">
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        </div>
    </form>
}
